-- 1. Criação da Tabela (idempotente)
DO $$
BEGIN
  IF NOT EXISTS (
    SELECT 1
    FROM information_schema.tables
    WHERE table_schema = 'public'
      AND table_name = 'infraestrutura_energia'
  ) THEN
    CREATE TABLE public.infraestrutura_energia (
      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
      pais TEXT NOT NULL,
      regiao TEXT NOT NULL,
      cidade TEXT NOT NULL,
      fonte_energia TEXT NOT NULL,
      uso_principal TEXT NOT NULL,
      ano_instalacao INT NOT NULL,
      created_at TIMESTAMPTZ DEFAULT NOW()
    );
  END IF;
END $$;

-- 2. Habilitar RLS (safe to run multiple times)
ALTER TABLE public.infraestrutura_energia ENABLE ROW LEVEL SECURITY;

